# =============================================================================
# Property Management System - Environment Variables
# =============================================================================
# Copy this file to .env (root) or .env.local in each app and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (shared by API, admin-portal, tenant-portal)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (API only - never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# API (apps/api)
# -----------------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0

# JWT
JWT_SECRET=your-jwt-secret-for-signing-and-verification

# Optional: CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# Admin Portal (apps/admin-portal)
# -----------------------------------------------------------------------------
# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API base URL for server/API calls
NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Tenant Portal (apps/tenant-portal)
# -----------------------------------------------------------------------------
# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3001

# API base URL for server/API calls
NEXT_PUBLIC_API_URL=http://localhost:4000
